{
  "_comment": "Preset tinh chỉnh hệ thống qua `settings put` và `device_config`. Tất cả có thể đảo ngược.",
  "presets": [
    {
      "id": "animations_off",
      "icon": "⚡",
      "category": "Tốc độ",
      "title": "Tắt animation hoàn toàn",
      "description": "Bỏ 3 loại animation chuyển cảnh — máy phản hồi tức thì khi chạm. Tác động lớn nhất, dễ thấy nhất.",
      "apply": [
        {"namespace": "global", "key": "window_animation_scale", "value": "0"},
        {"namespace": "global", "key": "transition_animation_scale", "value": "0"},
        {"namespace": "global", "key": "animator_duration_scale", "value": "0"}
      ],
      "revert": [
        {"namespace": "global", "key": "window_animation_scale", "value": "1"},
        {"namespace": "global", "key": "transition_animation_scale", "value": "1"},
        {"namespace": "global", "key": "animator_duration_scale", "value": "1"}
      ]
    },
    {
      "id": "animations_half",
      "icon": "🌀",
      "category": "Tốc độ",
      "title": "Animation 50% (cân bằng đẹp / nhanh)",
      "description": "Giảm 50% — vẫn có hiệu ứng nhưng mượt nhanh.",
      "apply": [
        {"namespace": "global", "key": "window_animation_scale", "value": "0.5"},
        {"namespace": "global", "key": "transition_animation_scale", "value": "0.5"},
        {"namespace": "global", "key": "animator_duration_scale", "value": "0.5"}
      ],
      "revert": [
        {"namespace": "global", "key": "window_animation_scale", "value": "1"},
        {"namespace": "global", "key": "transition_animation_scale", "value": "1"},
        {"namespace": "global", "key": "animator_duration_scale", "value": "1"}
      ]
    },
    {
      "id": "background_limit_3",
      "icon": "📊",
      "category": "Hiệu năng",
      "title": "Giới hạn 3 process nền",
      "description": "Chỉ cho 3 app chạy nền. Tiết kiệm RAM mạnh, tốt cho máy phụ ít dùng đa nhiệm.",
      "warning": "Chat/nhạc khi không mở app có thể bị đóng.",
      "apply": [
        {"shell": "device_config put activity_manager max_phantom_processes 3"}
      ],
      "revert": [
        {"shell": "device_config delete activity_manager max_phantom_processes"}
      ]
    },
    {
      "id": "force_dark_mode",
      "icon": "🌙",
      "category": "Hiển thị",
      "title": "Bật dark mode toàn hệ thống",
      "description": "Một số app chưa hỗ trợ dark sẽ bị ép tối — tiết kiệm pin OLED.",
      "apply": [
        {"namespace": "secure", "key": "ui_night_mode", "value": "2"}
      ],
      "revert": [
        {"namespace": "secure", "key": "ui_night_mode", "value": "1"}
      ]
    },
    {
      "id": "always_on_display_off",
      "icon": "🔋",
      "category": "Pin",
      "title": "Tắt Always-On Display",
      "description": "Tắt màn hình hiển thị 24/7 — pin trâu hơn rõ rệt.",
      "apply": [
        {"namespace": "secure", "key": "doze_always_on", "value": "0"}
      ],
      "revert": [
        {"namespace": "secure", "key": "doze_always_on", "value": "1"}
      ]
    },
    {
      "id": "disable_lift_to_wake",
      "icon": "🔋",
